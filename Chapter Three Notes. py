# The method is called rstrip ---> I will be able to combine the two lines into single one
file = "genomic_dna.txt"
my_file = open(file)
my_file_contents = my_file.read()

dna = my_file_contents.rstrip("\n") # ---> here, I used the method rstrip("\n") to remove the new line created

dna_length = len(my_file_contents)

print("The sequence is " + dna + ", and its length is " + str(dna_length))



